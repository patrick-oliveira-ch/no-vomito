<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1A1A1A">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No Vomito"
        android:textSize="28sp"
        android:textColor="#FFFFFFFF"
        android:textStyle="bold"
        android:layout_marginTop="40dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="by Patapps"
        android:textSize="14sp"
        android:textColor="#FF888888"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Inactif"
        android:textSize="16sp"
        android:textColor="#FFAAAAAA"
        android:layout_marginTop="32dp"/>

    <Button
        android:id="@+id/toggleButton"
        android:layout_width="200dp"
        android:layout_height="56dp"
        android:text="Démarrer"
        android:textSize="18sp"
        android:layout_marginTop="24dp"
        android:backgroundTint="#FF4CAF50"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Couleur des points"
        android:textSize="14sp"
        android:textColor="#FFAAAAAA"
        android:layout_marginTop="32dp"/>

    <LinearLayout
        android:id="@+id/colorPicker"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp">

        <View android:id="@+id/colorBlack"
            android:layout_width="40dp" android:layout_height="40dp"
            android:layout_margin="4dp" android:background="#FF000000"/>
        <View android:id="@+id/colorGray"
            android:layout_width="40dp" android:layout_height="40dp"
            android:layout_margin="4dp" android:background="#FF666666"/>
        <View android:id="@+id/colorWhite"
            android:layout_width="40dp" android:layout_height="40dp"
            android:layout_margin="4dp" android:background="#FFFFFFFF"/>
        <View android:id="@+id/colorBlue"
            android:layout_width="40dp" android:layout_height="40dp"
            android:layout_margin="4dp" android:background="#FF2196F3"/>
        <View android:id="@+id/colorGreen"
            android:layout_width="40dp" android:layout_height="40dp"
            android:layout_margin="4dp" android:background="#FF4CAF50"/>
        <View android:id="@+id/colorRed"
            android:layout_width="40dp" android:layout_height="40dp"
            android:layout_margin="4dp" android:background="#FFF44336"/>
        <View android:id="@+id/colorOrange"
            android:layout_width="40dp" android:layout_height="40dp"
            android:layout_margin="4dp" android:background="#FFFF9800"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nombre de points"
        android:textSize="14sp"
        android:textColor="#FFAAAAAA"
        android:layout_marginTop="28dp"/>

    <SeekBar
        android:id="@+id/gridDensitySeek"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:max="10"
        android:progress="5"/>

    <TextView
        android:id="@+id/gridDensityLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="55 points"
        android:textSize="12sp"
        android:textColor="#FF777777"
        android:layout_marginTop="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Opacité"
        android:textSize="14sp"
        android:textColor="#FFAAAAAA"
        android:layout_marginTop="28dp"/>

    <SeekBar
        android:id="@+id/alphaSeek"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:max="100"
        android:progress="45"/>

    <TextView
        android:id="@+id/alphaLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="45%"
        android:textSize="12sp"
        android:textColor="#FF777777"
        android:layout_marginTop="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sensibilité"
        android:textSize="14sp"
        android:textColor="#FFAAAAAA"
        android:layout_marginTop="20dp"/>

    <SeekBar
        android:id="@+id/sensitivitySeek"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:max="100"
        android:progress="50"/>

    <TextView
        android:id="@+id/sensitivityLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="50%"
        android:textSize="12sp"
        android:textColor="#FF777777"
        android:layout_marginTop="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vitesse de défilement"
        android:textSize="14sp"
        android:textColor="#FFAAAAAA"
        android:layout_marginTop="20dp"/>

    <SeekBar
        android:id="@+id/scrollSpeedSeek"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:max="100"
        android:progress="30"/>

    <TextView
        android:id="@+id/scrollSpeedLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="30%"
        android:textSize="12sp"
        android:textColor="#FF777777"
        android:layout_marginTop="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vitesse minimum (km/h)"
        android:textSize="14sp"
        android:textColor="#FFAAAAAA"
        android:layout_marginTop="20dp"/>

    <SeekBar
        android:id="@+id/minSpeedSeek"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:max="50"
        android:progress="0"/>

    <TextView
        android:id="@+id/minSpeedLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Désactivé"
        android:textSize="12sp"
        android:textColor="#FF777777"
        android:layout_marginTop="4dp"/>

    <Button
        android:id="@+id/updateButton"
        android:layout_width="200dp"
        android:layout_height="44dp"
        android:text="Vérifier mise à jour"
        android:textSize="13sp"
        android:layout_marginTop="32dp"
        android:backgroundTint="#FF333333"
        android:textColor="#FFAAAAAA"/>

    <TextView
        android:id="@+id/versionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0.0"
        android:textSize="12sp"
        android:textColor="#FF555555"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="24dp"/>

</LinearLayout>
</ScrollView>
